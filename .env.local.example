# ── Resend (email notifications) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=quotes@handyrescue.com

# ── Twilio (SMS notifications) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# ── Site URL (defaults to siteConfig.url if not set) ────────────
# Set this to your Vercel URL until you have a custom domain
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Business ────────────────────────────────────────────────────
BUSINESS_EMAIL=owner@handyrescue.com
BUSINESS_PHONE_NUMBER=+15551234567
